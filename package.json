{
  "name": "seojuice",
  "version": "1.1.0",
  "description": "Official SEOJuice SDK for Node.js - Intelligence API client and SEO injection helpers",
  "author": "SEOJuice",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./injection": {
      "import": {
        "types": "./dist/injection.d.mts",
        "default": "./dist/injection.mjs"
      },
      "require": {
        "types": "./dist/injection.d.ts",
        "default": "./dist/injection.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0",
    "typescript": "^5.4",
    "vitest": "^3.0"
  },
  "keywords": [
    "seo",
    "seojuice",
    "analytics",
    "intelligence",
    "api",
    "sdk",
    "nextjs",
    "react",
    "vue",
    "angular",
    "svelte"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calm-north/seojuice-js.git"
  },
  "homepage": "https://seojuice.com"
}
